  function scrollToBookingForm(offset = 10) {
    $('html, body').stop().animate(
      {
        scrollTop: $bookingForm.offset().top - offset
      },
      600
    );
  }

  let lastHeight = $bookingForm.outerHeight();

  const resizeObserver = new ResizeObserver(() => {
    if (!isMobile()) return;

    const newHeight = $bookingForm.outerHeight();

    if (newHeight !== lastHeight) {
      lastHeight = newHeight;

      setTimeout(() => {
        scrollToBookingForm();
      }, 250);
    }
  });

  resizeObserver.observe($bookingForm[0]);

});
